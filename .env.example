SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_insert_key

# Legacy Supabase projects can use this instead of SUPABASE_PUBLISHABLE_KEY:
# SUPABASE_ANON_KEY=your_legacy_anon_key

# Server-only keys are also supported, but the public waitlist insert policy
# works with a publishable/anon key and is easier to configure.
# SUPABASE_SECRET_KEY=sb_secret_your_server_only_key
# SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_key
